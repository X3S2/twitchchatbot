# ============================================================
# TwitchChatBot (TCB) — Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an.
# NIEMALS .env in Git einchecken!
# ============================================================

# ── Externer Port (wird von nginx nach außen exponiert) ──────
TCB_EXTERNAL_PORT=3080

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=tcb
POSTGRES_USER=tcb_user
POSTGRES_PASSWORD=SICHERES_PASSWORT_HIER_EINTRAGEN
DATABASE_URL=postgresql+asyncpg://tcb_user:SICHERES_PASSWORT_HIER_EINTRAGEN@tcb-postgres:5432/tcb

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://tcb-redis:6379/0

# ── Sicherheit ───────────────────────────────────────────────
# 32-Byte-Schlüssel für JWT (z.B. via: openssl rand -hex 32)
JWT_SECRET_KEY=HIER_LANGEN_ZUFAELLIGEN_STRING_EINTRAGEN

# Fernet-Schlüssel für verschlüsselte DB-Felder (Token etc.)
# Generieren mit: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=HIER_FERNET_KEY_EINTRAGEN

# ── App-Einstellungen ────────────────────────────────────────
# Öffentliche URL der Anwendung (für Twitch OAuth Redirect URI)
# Lokal: http://localhost:3080
# Produktion: https://deine-domain.ipv64.net
APP_PUBLIC_URL=http://localhost:3080

# ── Bot-Manager (intern) ─────────────────────────────────────
BOT_MANAGER_URL=http://tcb-botmanager:8001

# ── Backup-Einstellungen ─────────────────────────────────────
BACKUP_RETENTION_DAYS=7
